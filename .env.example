# 配置说明详见 README「前提条件」「首次使用」，完整变量表见 DEVELOPER.md §6。
# 每项一句话点题，不在此重复细节。

# Slack 凭证：Bot Token（xoxb-）/ App-Level Token（xapp-，需 connections:write）
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 种子用户：你的 Slack 用户 ID（U 开头，逗号分隔）。必填，否则发不出第一条
SLACK_DEFAULT_USERS=

# 每日推送时间（24 小时制 HH:MM）。用的是「你这台电脑显示的本地时间」——
# 电脑几点，就几点推，不用换算时区。改完重跑 install 脚本生效。默认 10:00。
PUSH_TIME=10:00

# LLM（OpenAI 兼容接口，用于重排 + 摘要）
GENREC_ENDPOINT=https://api.deepseek.com/v1/chat/completions
GENREC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GENREC_MODEL=deepseek-chat

# GitHub Personal Access Token（可选）：仅用于查询 repo 描述与 README，避免出口 IP 共享时被
# 60/小时限速命中 → GitHub 卡片显示"暂无简介"。生成方式见 README「前提条件」。无权限要求。
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 数据/日志目录（可选，默认 ~/.tech-digest）
# TECH_DIGEST_DATA_DIR=/path/to/your/data/dir

# 中国大陆无代理（可选）：HF 走镜像 + 跳过 Anthropic
# HF_ENDPOINT=https://hf-mirror.com
# TECH_DIGEST_MODE=daily

# 出海代理（可选）：填了可直连官方源、保留全部三个数据源
# TECH_DIGEST_PROXY=http://127.0.0.1:7890
